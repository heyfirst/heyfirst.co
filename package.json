{
	"name": "heyfirst-astro",
	"version": "6.1.1",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro build",
		"postbuild": "pagefind --site .vercel/output/static",
		"preview": "astro preview",
		"lint": "biome lint .",
		"format": "bun run format:code && bun run format:imports",
		"format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
		"format:imports": "biome check --formatter-enabled=false --write",
		"check": "astro check"
	},
	"dependencies": {
		"@astrojs/markdown-remark": "7.2.1",
		"@astrojs/mdx": "7.0.2",
		"@astrojs/rss": "4.0.19",
		"@astrojs/sitemap": "3.7.3",
		"@astrojs/vercel": "11.0.2",
		"@tailwindcss/vite": "4.3.2",
		"astro": "7.0.6",
		"astro-expressive-code": "0.44.0",
		"astro-icon": "1.1.5",
		"astro-robots-txt": "1.0.0",
		"astro-webmanifest": "1.0.0",
		"cssnano": "7.1.0",
		"hastscript": "9.0.1",
		"mdast-util-directive": "3.1.0",
		"mdast-util-to-markdown": "2.1.2",
		"mdast-util-to-string": "4.0.0",
		"rehype-autolink-headings": "7.1.0",
		"rehype-external-links": "3.0.0",
		"rehype-unwrap-images": "1.0.0",
		"remark-directive": "4.0.0",
		"satori": "0.16.2",
		"satori-html": "0.3.2",
		"sharp": "0.34.3",
		"ultrahtml": "1.6.0",
		"unified": "11.0.5",
		"unist-util-visit": "5.0.0"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@biomejs/biome": "2.1.4",
		"@iconify-json/mdi": "1.2.3",
		"@pagefind/default-ui": "1.3.0",
		"@resvg/resvg-js": "2.6.2",
		"@tailwindcss/typography": "0.5.16",
		"@types/hast": "3.0.4",
		"@types/mdast": "4.0.4",
		"autoprefixer": "10.4.21",
		"pagefind": "1.3.0",
		"prettier": "3.6.2",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "0.6.14",
		"reading-time": "1.5.0",
		"tailwindcss": "4.3.2",
		"typescript": "5.9.2"
	},
	"trustedDependencies": [
		"@biomejs/biome",
		"esbuild",
		"sharp"
	]
}
