---
import { type CollectionEntry, getCollection } from "astro:content";
import SocialList from "@/components/SocialList.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import ProjectList from "@/components/ProjectList.astro";
import SnippetCard from "@/components/SnippetCard.astro";
import { getAllPosts } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";
import { sortProjectsByOrder } from "@/utils/project";

// Writing
const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = allPosts
	.sort(collectionDateSort)
	.slice(0, MAX_POSTS) as CollectionEntry<"post">[];

// Snippets
const MAX_SNIPPETS = 5;
const allSnippets = await getCollection("snippet");
const latestSnippets = allSnippets.sort(collectionDateSort).slice(0, MAX_SNIPPETS);

// Projects
const allProjects = await getCollection("project");
const sortedProjects = sortProjectsByOrder(allProjects);
---

<PageLayout meta={{ title: "Home" }}>
	<section>
		<h1 class="title mb-6">Hey there!</h1>
		<p class="mb-4">
			I'm a software engineer at <a class="underline" href="https://swarmia.com">Swarmia</a>. Living
			in Helsinki, Finland. Previously, I worked at{' '}
			<a class="underline" href="https://unity.com">Unity</a>, and{' '}
			<a class="underline" href="https://thoughtworks.com">Thoughtworks</a>.
		</p>
		<SocialList />
	</section>

	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl"><a href="/posts/">Writing</a></h2>
		<ul class="space-y-4" role="list">
			{
				allPostsByDate.map((p) => (
					<li class="grid gap-2 sm:grid-cols-[auto_1fr]">
						<PostPreview post={p} />
					</li>
				))
			}
		</ul>
	</section>

	{
		latestSnippets.length > 0 && (
			<section class="mt-16">
				<h2 class="title text-accent text-xl">
					<a href="/snippets/">Snippets</a>
				</h2>
				<p class="mb-6 text-sm text-gray-600 dark:text-gray-400">
					Short-form code notes and things I picked up along the way.
				</p>
				<ul class="grid gap-4 sm:grid-cols-2" role="list">
					{latestSnippets.map((snippet) => (
						<SnippetCard snippet={snippet} />
					))}
				</ul>
			</section>
		)
	}

	<section class="mt-16">
		<h2 class="title text-accent text-xl">
			<a href="/projects/">Projects</a>
		</h2>
		<p class="mb-6 text-sm text-gray-600 dark:text-gray-400">Things I've built and maintain.</p>
		<ProjectList projects={sortedProjects} />
	</section>
</PageLayout>
