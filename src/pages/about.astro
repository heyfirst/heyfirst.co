---
import SocialList from "@/components/SocialList.astro";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";

const meta = {
	description: siteConfig.description,
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			I'm a software engineer at <a href="https://swarmia.com">Swarmia</a>, living in Helsinki,
			Finland. Born and raised in Chiang Mai, Thailand. {" "}
      Before moving to Finland, I worked at <a href="https://unity.com">Unity</a> and{" "}
			<a href="https://thoughtworks.com">Thoughtworks</a>.
		</p>
		<p>
			My day-to-day work centers on web (full stack) development, from frontend to backend to database to infrastructure,
      including messaging, distributed systems, and high-performance PostgreSQL. On this site I write about the same territory,
      as well as my personal projects and experiments. I loves exploring new technologies, and I enjoy sharing my
      findings with the community. such as Sveltekit, Clickhouse, Self-hosted stuff, and other stuff.
		</p>
		<p>
			Outside of work, I'm generally tinkering with something — my first PC build is one of the posts here.
      I enjoy hiking, bouldering and I also like to explore new cities and countries.
      I also enjoy reading, especially non-fiction books about autography, travel journey and yes, of course, technology.
		</p>
	</div>
	<div class="mt-8">
		<SocialList />
	</div>
</PageLayout>
