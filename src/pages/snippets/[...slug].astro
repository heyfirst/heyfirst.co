---
import { getCollection } from "astro:content";

import Snippet from "@/components/snippet/Snippet.astro";
import PageLayout from "@/layouts/Base.astro";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

// if you're using an adaptor in SSR mode, getStaticPaths wont work -> https://docs.astro.build/en/guides/routing/#modifying-the-slug-example-for-ssr
export const getStaticPaths = (async () => {
	const allSnippets = await getCollection("snippet");
	return allSnippets.map((snippet) => ({
		params: { slug: snippet.id },
		props: { snippet },
	}));
}) satisfies GetStaticPaths;

export type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { snippet } = Astro.props;

const meta = {
	description:
		snippet.data.description ||
		`Read about my snippet posted on: ${snippet.data.publishDate.toLocaleDateString()}`,
	title: snippet.data.title,
};
---

<PageLayout meta={meta}>
	<Snippet as="h1" snippet={snippet} />
</PageLayout>
